{
  "name": "@gravcn/ui",
  "version": "0.1.2",
  "description": "CLI to add gravcn UI components to your project",
  "type": "module",
  "bin": {
    "gravcn-ui": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --minify --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "publish": "npm publish --access public",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^13.1.0",
    "execa": "^9.0.0",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.4.5"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ui",
    "components",
    "cli",
    "gravcn"
  ]
}
